            };
        }

        function setEditorValidationState(editor, message) {
            if (!editor) return;

            editor.option({
                isValid: !message,
                validationError: message ? { message: message } : null
            });
        }

        function clearEditorValidation(editors) {
            setEditorValidationState(editors.account, null);
            setEditorValidationState(editors.fromDate, null);
            setEditorValidationState(editors.toDate, null);
        }

        function normalizeDateParamValue(value) {
            if (!value) return null;

            const dateValue = value instanceof Date ? value : new Date(value);
            if (isNaN(dateValue.getTime())) return null;

            const year = dateValue.getFullYear();
            const month = String(dateValue.getMonth() + 1).padStart(2, "0");
            const day = String(dateValue.getDate()).padStart(2, "0");
            return year + "-" + month + "-" + day;
        }

        function validateSearchCriteria(editors) {
            const accountIds = editors.account ? editors.account.option("value") : [];
            const fromDate = editors.fromDate ? editors.fromDate.option("value") : null;
            const toDate = editors.toDate ? editors.toDate.option("value") : null;
            const hasAccount = Array.isArray(accountIds) && accountIds.length > 0;
            const hasFromDate = !!fromDate;
            const hasToDate = !!toDate;

            clearEditorValidation(editors);

            let isValid = true;

            if (!hasAccount) {
                setEditorValidationState(editors.account, "د حساب ټاکل ضروري دي.");
                isValid = false;
            }

            if (!hasFromDate) {
                setEditorValidationState(editors.fromDate, "د شروع نېټه ضروري ده.");
                isValid = false;
            }

            if (!hasToDate) {
                setEditorValidationState(editors.toDate, "د پای نېټه ضروري ده.");
                isValid = false;
            }

            if (!isValid) {
                return false;
            }

            if (new Date(toDate) < new Date(fromDate)) {
                const rangeMessage = "د پای نېټه باید د شروع نېټې سره برابره یا وروسته وي.";
                setEditorValidationState(editors.toDate, rangeMessage);
                return false;
            }

            return true;
        }

        function applySearchFilters(filters) {
            activeSearchFilters.accountIds = filters.accountIds;
            activeSearchFilters.fromDate = filters.fromDate;
            activeSearchFilters.toDate = filters.toDate;
        }

        function buildSearchFiltersFromEditors(editors) {
            return {
                accountIds: (editors.account ? editors.account.option("value") : []).map(Number),
                fromDate: normalizeDateParamValue(editors.fromDate ? editors.fromDate.option("value") : null),
                toDate: normalizeDateParamValue(editors.toDate ? editors.toDate.option("value") : null)
            };
        }

