        async function handleSave() {
            if (!formInstance) return;
            const validation = formInstance.validate();
            if (!validation.isValid) return;
            const validationMessage = getExchangeValidationMessage() || getRestrictedNegativeValidationMessage();
            if (validationMessage) {
                updateAmountValidationState();
                DevExpress.ui.notify(validationMessage, "error", 3000);
                return;
            }

            const formData = formInstance.option("formData") ?? {};
            const payload = new FormData();
            payload.append("DebitCurrencyId", toInvariantNumberString(formData.DebitCurrencyId, ""));
            payload.append("CreditCurrencyId", toInvariantNumberString(formData.CreditCurrencyId, ""));
            payload.append("ExchangeRate", toInvariantNumberString(formData.ExchangeRate, "0"));
            payload.append("DebitAccountId", toInvariantNumberString(formData.DebitAccountId, ""));
            payload.append("CreditAccountId", toInvariantNumberString(formData.CreditAccountId, ""));
            payload.append("Amount", toInvariantNumberString(formData.Amount, "0"));
            payload.append("Remarks", String(formData.Remarks ?? "").trim());
            if (selectedChequePhotoFile) {
                payload.append("ChequePhoto", selectedChequePhotoFile);
            }

            try {
                const response = await fetch("/api/accounts/journal-entry", {
                    method: "POST",
                    credentials: "same-origin",
                    headers: {
                        "X-Requested-With": "XMLHttpRequest"
                    },
                    body: payload
                });

                const result = await response.json().catch(() => ({}));
                if (!response.ok) {
                    DevExpress.ui.notify(result?.Message || "د ژورنال ثبت ناکام سو.", "error", 3500);
                    return;
                }

                const debitBalanceIndex = accountBalances.findIndex(item =>
                    item.AccountID === Number(formData.DebitAccountId) &&
                    item.CurrencyID === Number(formData.DebitCurrencyId)
                );

                if (debitBalanceIndex >= 0) {
                    accountBalances[debitBalanceIndex].Balance = Number(result?.DebitAccountBalance ?? accountBalances[debitBalanceIndex].Balance);
                } else {
                    accountBalances.push({
                        AccountID: Number(formData.DebitAccountId),
                        CurrencyID: Number(formData.DebitCurrencyId),
                        Balance: Number(result?.DebitAccountBalance ?? 0)
                    });
                }

                const creditBalanceIndex = accountBalances.findIndex(item =>
                    item.AccountID === Number(formData.CreditAccountId) &&
                    item.CurrencyID === Number(formData.CreditCurrencyId)
                );

                if (creditBalanceIndex >= 0) {
                    accountBalances[creditBalanceIndex].Balance = Number(result?.CreditAccountBalance ?? accountBalances[creditBalanceIndex].Balance);
                } else {
                    accountBalances.push({
                        AccountID: Number(formData.CreditAccountId),
                        CurrencyID: Number(formData.CreditCurrencyId),
                        Balance: Number(result?.CreditAccountBalance ?? 0)
                    });
                }

                if (Array.isArray(result?.JournalEntries) && result.JournalEntries.length) {
                    const journalGrid = getJournalEntryGridInstance();
                    journalGrid?.getDataSource()?.reload();
                }

                updateBalanceNotes();
                updateSummary();
                DevExpress.ui.notify("ژورنال ثبت سو.", "success", 2500);
                popupInstance?.hide();
            } catch {
                DevExpress.ui.notify("د ژورنال ثبت ناکام سو.", "error", 3500);
            }
        }

