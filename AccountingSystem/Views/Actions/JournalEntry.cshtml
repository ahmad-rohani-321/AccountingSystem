            formInstance.updateData("CreditAccountId", creditAccountId ?? null);
        }

        function updateAccountEditors(debitAccountId, forceResetCredit = false) {
            if (!formInstance) {
                return;
            }

            const debitEditor = formInstance.getEditor("DebitAccountId");
            debitEditor?.option("items", debitAccountSource);

            const creditSource = getCreditAccountSource(debitAccountId);
            const formData = formInstance.option("formData") ?? {};
            const hasSelectedCredit = !forceResetCredit && creditSource.some(acc => acc.ID === Number(formData.CreditAccountId));
            const nextCreditAccountId = hasSelectedCredit ? formData.CreditAccountId : null;

            if ((forceResetCredit || !hasSelectedCredit) && formData.CreditAccountId !== null) {
                formInstance.updateData("CreditAccountId", null);
            }

            syncCreditEditor(creditSource, nextCreditAccountId);

            updateBalanceNotes();
            updateSummary();
        }

