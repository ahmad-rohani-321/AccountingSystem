                                template: () => {
                                    const wrapper = $("<div></div>");
                                    wrapper.append("<label class='form-label d-block mb-2'>د سند عکس (.jpg)</label>");
                                    const uploader = $("<div></div>").dxFileUploader({
                                        multiple: false,
                                        accept: ".jpg",
                                        uploadMode: "useForm",
                                        selectButtonText: "عکس انتخاب کړئ",
                                        labelText: "",
                                        allowedFileExtensions: [".jpg"],
                                        invalidFileExtensionMessage: "یوازې .jpg فایل منل کېږي.",
                                        onValueChanged: e => {
                                            selectedChequePhotoFile = e.value?.[0] ?? null;
                                            formInstance?.updateData("ChequePhoto", selectedChequePhotoFile ? selectedChequePhotoFile.name : null);
                                        }
                                    });
                                    chequePhotoUploaderInstance = uploader.dxFileUploader("instance");
                                    wrapper.append(uploader);
                                    return wrapper;
                                }
                            }
                        ]
                    }).dxForm("instance");

                    body.append(formSection).append(summarySection);
                    content.append(body);
                    resetForm();
                }
            }).dxPopup("instance");
        }

        window.openJournalEntryPopup = async () => {
            try {
                await ensurePageDataLoaded();
                if (!popupInstance) {
                    initPopup();
                }
                popupInstance?.show();
            } catch {
                DevExpress.ui.notify("د ژورنال معلومات رانغلله نه.", "error", 3000);
            }
        };

        document.addEventListener("DOMContentLoaded", () => {
            ensurePageDataLoaded()
                .then(initPopup)
                .catch(() => DevExpress.ui.notify("د ژورنال معلومات رانغلله نه.", "warning", 3000));
        });
    })();
</script>
