        function syncCreditEditor(creditSource, creditAccountId) {
            if (!formInstance) {
                return;
            }

            const creditEditorOptions = {
                items: creditSource,
                disabled: creditSource.length === 0,
                valueExpr: "ID",
                displayExpr: "DisplayName",
                placeholder: "حساب انتخاب کړئ...",
                searchEnabled: true,
                onValueChanged: () => {
                    updateBalanceNotes();
                    updateSummary();
