        function loadPurchaseIntoReturnPopup(purchaseId) {
            if (!purchaseId) return;

            ensureReturnPopup();

            if (!returnPopupContentInitialized) {
                pendingReturnPurchaseId = purchaseId;
                return;
            }

            clearReturnPopupForm();
            setReturnPopupLoadingState(true, "معلومات ترلاسه کېږي...");

            $.when(refreshReturnItemCache(), refreshReturnWarehouseCache())
                .always(function () {
                    $.getJSON(salesApiBaseUrl + purchaseId)
                        .done(function (response) {
                            populateReturnPopup(response || {});
                        })
                        .fail(function (xhr) {
                            clearReturnPopupForm();
                            setReturnPopupLoadingState(false, "د خرید معلومات دلته ښکاري.");
                            DevExpress.ui.notify((xhr && xhr.responseJSON && xhr.responseJSON.Message) ? xhr.responseJSON.Message : "د خرید معلومات ترلاسه نه شول.", "error", 3200);
                        });
                });
        }

        function refreshReceiveTreasureBalanceLabel() {
            var treasureEditor = $("#purchaseReceiveTreasure").dxSelectBox("instance");
            var treasureId = treasureEditor ? treasureEditor.option("value") : null;

            if (!treasureId || !currentReceiveCurrencyId) {
                resetBalanceLabel("#purchaseReceiveTreasureBalance");
                return;
            }

            $.ajax({
                url: "/api/Accounts/balance",
                method: "GET",
                data: {
                    accountId: treasureId,
                    currencyId: currentReceiveCurrencyId
                }
            }).done(function (result) {
                var balance = result && result.Balance !== undefined ? Number(result.Balance) : 0;
                setBalanceLabel("#purchaseReceiveTreasureBalance", currentReceiveCurrencyName || "اسعار", balance);
            }).fail(function () {
                resetBalanceLabel("#purchaseReceiveTreasureBalance");
            });
        }

        function refreshReceiveAccountBalanceLabel() {
            if (!currentReceiveAccountId || !currentReceiveCurrencyId) {
                resetBalanceLabel("#purchaseReceiveAccountBalance");
                return;
            }

            $.ajax({
                url: "/api/Accounts/balance",
                method: "GET",
                data: {
                    accountId: currentReceiveAccountId,
                    currencyId: currentReceiveCurrencyId
                }
            }).done(function (result) {
                var balance = result && result.Balance !== undefined ? Number(result.Balance) : 0;
                setBalanceLabel("#purchaseReceiveAccountBalance", currentReceiveCurrencyName || "اسعار", balance);
            }).fail(function () {
                resetBalanceLabel("#purchaseReceiveAccountBalance");
            });
        }

        function updateReceiveCalculatedFields() {
            var amountEditor = $("#purchaseReceiveAmount").dxNumberBox("instance");
            var receivedEditor = $("#purchaseReceiveReceived").dxNumberBox("instance");
            var remainingEditor = $("#purchaseReceiveRemaining").dxNumberBox("instance");
            var newReceivedEditor = $("#purchaseReceiveNewReceived").dxNumberBox("instance");
            var newRemainingEditor = $("#purchaseReceiveNewRemaining").dxNumberBox("instance");

            var amount = amountEditor ? Number(amountEditor.option("value") || 0) : 0;
            var received = receivedEditor ? Number(receivedEditor.option("value") || 0) : 0;
            var remaining = remainingEditor ? Number(remainingEditor.option("value") || 0) : 0;

            if (newReceivedEditor) {
                newReceivedEditor.option("value", received + Math.max(0, amount));
            }

            if (newRemainingEditor) {
                newRemainingEditor.option("value", Math.max(0, remaining - Math.max(0, amount)));
            }
        }

        function clearReceivePopupForm() {
            var fieldConfigs = [
                { selector: "#purchaseReceiveNo", widget: "dxNumberBox", value: null },
                { selector: "#purchaseReceiveAccount", widget: "dxTextBox", value: "" },
                { selector: "#purchaseReceiveCurrency", widget: "dxTextBox", value: "" },
                { selector: "#purchaseReceiveDate", widget: "dxDateBox", value: null },
                { selector: "#purchaseReceiveTotal", widget: "dxNumberBox", value: 0 },
                { selector: "#purchaseReceiveReceived", widget: "dxNumberBox", value: 0 },
                { selector: "#purchaseReceiveRemaining", widget: "dxNumberBox", value: 0 },
                { selector: "#purchaseReceiveNotes", widget: "dxTextArea", value: "" },
                { selector: "#purchaseReceiveTreasure", widget: "dxSelectBox", value: null },
                { selector: "#purchaseReceiveAmount", widget: "dxNumberBox", value: null },
                { selector: "#purchaseReceiveNewReceived", widget: "dxNumberBox", value: 0 },
                { selector: "#purchaseReceiveNewRemaining", widget: "dxNumberBox", value: 0 }
            ];

            for (var i = 0; i < fieldConfigs.length; i++) {
                var config = fieldConfigs[i];
                var instance = $(config.selector)[config.widget]("instance");
                if (instance) instance.option("value", config.value);
            }

            currentReceivePurchaseId = null;
            currentReceiveAccountId = 0;
            currentReceiveCurrencyId = 0;
            currentReceiveCurrencyName = "";
            currentReceiveAccountName = "";
            resetBalanceLabel("#purchaseReceiveAccountBalance");
            resetBalanceLabel("#purchaseReceiveTreasureBalance");
        }

        function setReceiveFieldValidationState(editor, message) {
            if (!editor) return;

            editor.option({
                isValid: !message,
                validationError: message ? { message: message } : null
            });
        }

        function validateReceiveForm() {
            var treasureEditor = $("#purchaseReceiveTreasure").dxSelectBox("instance");
            var amountEditor = $("#purchaseReceiveAmount").dxNumberBox("instance");
            var remainingEditor = $("#purchaseReceiveRemaining").dxNumberBox("instance");

            var treasureId = treasureEditor ? treasureEditor.option("value") : null;
            var amount = amountEditor ? Number(amountEditor.option("value") || 0) : 0;
            var remaining = remainingEditor ? Number(remainingEditor.option("value") || 0) : 0;

            setReceiveFieldValidationState(treasureEditor, null);
            setReceiveFieldValidationState(amountEditor, null);

            if (!treasureId) {
                var treasureMessage = "تجري/بانک انتخاب کړئ.";
                setReceiveFieldValidationState(treasureEditor, treasureMessage);
                DevExpress.ui.notify(treasureMessage, "error", 3000);
                return false;
            }

            if (Number.isNaN(amount) || amount <= 0) {
                var amountMessage = "د رسید مبلغ باید له صفر څخه زیات وي.";
                setReceiveFieldValidationState(amountEditor, amountMessage);
                DevExpress.ui.notify(amountMessage, "error", 3000);
                return false;
            }

            if (amount > remaining) {
                var remainingMessage = "د رسید مبلغ د باقي مبلغ څخه زیات کېدای نه شي.";
                setReceiveFieldValidationState(amountEditor, remainingMessage);
                DevExpress.ui.notify(remainingMessage, "error", 3000);
                return false;
            }

            return true;
        }

        function buildReceivePayload() {
            var treasureEditor = $("#purchaseReceiveTreasure").dxSelectBox("instance");
            var amountEditor = $("#purchaseReceiveAmount").dxNumberBox("instance");

            return {
                TreasureAccountID: treasureEditor ? (treasureEditor.option("value") || null) : null,
                ReceiveAmount: amountEditor ? Number(amountEditor.option("value") || 0) : 0
            };
        }

        function populateReceivePopup(response) {
            var purchaseDate = response && response.SaleDate ? new Date(response.SaleDate) : null;
            var accountId = response && response.AccountID ? response.AccountID : null;
            var currencyId = response && response.CurrencyID ? response.CurrencyID : null;
            var treasureAccountId = response && response.TreasureAccountID ? response.TreasureAccountID : null;

            currentReceivePurchaseId = response && response.SaleID ? response.SaleID : null;
            currentReceiveAccountId = accountId || 0;
            currentReceiveCurrencyId = currencyId || 0;
            currentReceiveAccountName = response && response.AccountName ? response.AccountName : "";
            currentReceiveCurrencyName = response && response.CurrencyName ? response.CurrencyName : "";

            $("#purchaseReceiveNo").dxNumberBox("instance").option("value", response && response.SaleNo ? response.SaleNo : null);
            $("#purchaseReceiveAccount").dxTextBox("instance").option("value", currentReceiveAccountName || "");
            $("#purchaseReceiveCurrency").dxTextBox("instance").option("value", currentReceiveCurrencyName || "");
            $("#purchaseReceiveDate").dxDateBox("instance").option("value", purchaseDate);
            $("#purchaseReceiveTotal").dxNumberBox("instance").option("value", response && response.TotalAmount ? response.TotalAmount : 0);
            $("#purchaseReceiveReceived").dxNumberBox("instance").option("value", response && response.ReceivedAmount ? response.ReceivedAmount : 0);
            $("#purchaseReceiveRemaining").dxNumberBox("instance").option("value", response && response.RemainingAmount ? response.RemainingAmount : 0);
            $("#purchaseReceiveNotes").dxTextArea("instance").option("value", response && response.Remarks ? response.Remarks : "");
            $("#purchaseReceiveTreasure").dxSelectBox("instance").option("value", treasureAccountId);

            refreshReceiveAccountBalanceLabel();
            refreshReceiveTreasureBalanceLabel();
            updateReceiveCalculatedFields();
        }

        function onReceiveSaveClick() {
            if (!validateReceiveForm()) {
                return;
            }

            if (!currentReceivePurchaseId) {
                DevExpress.ui.notify("خرید ونه موندل شو.", "error", 2500);
                return;
            }

            $.ajax({
                url: salesApiBaseUrl + currentReceivePurchaseId + "/receive",
                method: "POST",
                contentType: "application/json; charset=utf-8",
                data: JSON.stringify(buildReceivePayload())
            }).done(function (response) {
                DevExpress.ui.notify("د خرید رسید ثبت شو.", "success", 2500);

                if (receivePopupInstance) {
                    receivePopupInstance.hide();
                }

                var grid = getGrid();
                if (grid) {
                    grid.refresh();
                }
            }).fail(function (xhr) {
                DevExpress.ui.notify("د خرید رسید ثبت نه شو. لطفاً اندازه، باقي مبلغ، او د تجري/بانک بلانس وګورئ.", "error", 3500);
            });
        }

