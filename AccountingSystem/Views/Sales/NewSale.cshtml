        function validatePurchaseGridRows(rows) {
            if (!rows || rows.length === 0) return "لږ تر لږه یو قطار اضافه کړئ.";

            for (var i = 0; i < rows.length; i++) {
                var row = rows[i] || {};
                if (!row.ItemID) return "په ټولو قطارونو کې جنس ضروري دی.";
                if (row.UnitConversionID === null || row.UnitConversionID === undefined || row.UnitConversionID === "") return "په ټولو قطارونو کې واحد ضروري دی.";
                if (row.Quantity === null || row.Quantity === undefined || row.Quantity === "" || Number(row.Quantity) <= 0) return "په ټولو قطارونو کې مقدار باید له صفر څخه زیات وي.";
                if (row.UnitPrice === null || row.UnitPrice === undefined || row.UnitPrice === "") return "په ټولو قطارونو کې قیمت ضروري دی.";
                if (!row.WarehouseID) return "په ټولو قطارونو کې ګدام ضروري دی.";
            }

            return "";
        }

        function validatePurchaseGrid() {
            var grid = getPurchaseGrid();
            if (!grid) return $.Deferred().resolve("د جنسونو جدول ونه موندل شو.").promise();

            var deferred = $.Deferred();

            $.when(grid.saveEditData())
                .done(function () {
                    var rows = getPurchaseGridRows();
                    var validationMessage = validatePurchaseGridRows(rows);

                    if (validationMessage) {
                        deferred.resolve(validationMessage);
                        return;
                    }

                    deferred.resolve("");
                })
                .fail(function () {
                    deferred.resolve("د جنسونو جدول معلومات سم نه دي.");
                });

            return deferred.promise();
        }

