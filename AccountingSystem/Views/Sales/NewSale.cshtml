@{
    ViewData["title"] ??= "نوی فروش";

}
<div class="dx-card px-4 py-3 mb-3">
    <div class="row row-cols-auto">
        <div class="col">
            @(
                Html.DevExtreme().Button()
                .ID("save-form")
                .Text("ثبت")
                .Icon("fa-solid fa-floppy-disk")
                .StylingMode(ButtonStylingMode.Contained)
                .Type(ButtonType.Success)
                .OnClick("purchasePage.onSaveFormClick")
            )
        </div>

        <div class="col">
            @(
                Html.DevExtreme().Button()
                .ID("clear-form")
                .Text("فورم پاکول")
                .Icon("fa-solid fa-eraser")
                .StylingMode(ButtonStylingMode.Contained)
                .Type(ButtonType.Normal)
                .OnClick("purchasePage.onClearFormClick")
            )
        </div>

        <div class="col">
            @(
                Html.DevExtreme().Button()
                .ID("select-order")
                .Text("آرډرونه")
                .Icon("fa-solid fa-clipboard-list")
                .StylingMode(ButtonStylingMode.Contained)
                .Type(ButtonType.Default)
                .OnClick("purchasePage.onSelectOrderClick")
            )
        </div>

    </div>

    <div class="row mt-3">
        <div class="col-12">
            <div id="purchase-hold-toggle-card" class="purchase-hold-toggle-card">
                <div class="purchase-hold-toggle-main">
                    @(
                        Html.DevExtreme().CheckBox()
                        .ID("is-holded")
                        .Text("که چک وي، فروش ساتل کېږي")
                        .Value(false)
                        .OnValueChanged("purchasePage.onIsHoldedChanged")
                    )
                </div>
                <small id="purchase-hold-summary" class="purchase-hold-summary">
                    فروش نه ساتل کیږي. د ثبت پر مهال به حسابونه او اړوند مالي اغېزې تطبیق سي.
                </small>
            </div>
        </div>
    </div>
</div>

<div class="dx-card px-4 py-3 mb-3 purchase-form-card">
    <div class="purchase-form-header">
        <div>
            <h5 class="purchase-form-title">د فروش معلومات</h5>
            <p class="purchase-form-subtitle">حساب، اسعار، بلانس او اړوند معلومات</p>
        </div>
    </div>
    <div class="row g-3 align-items-stretch">
        <div class="col-12 col-lg-4">
            <div class="purchase-field purchase-field-readonly">
                <label class="purchase-label">د فروش شمېره</label>
                @(Html.DevExtreme().NumberBox()
                   .ID("purchase-no")
                   .Placeholder("د فروش شمېره")
                )
            </div>
        </div>
        <div class="col-12 col-lg-4">
            <div class="purchase-field">
                <label class="purchase-label">حساب</label>
                @(
                    Html.DevExtreme().SelectBox()
                        .ID("account-selector")
                        .ValueExpr("AccountID")
                        .DisplayExpr(new JS("purchasePage.accountDisplayExpr"))
                        .SearchEnabled(true)
                        .ShowClearButton(true)
                        
                        .Placeholder("حساب انتخاب کړئ...")
                        .OnSelectionChanged("purchasePage.onAccountSelectionChanged")
                        .OnValueChanged("purchasePage.onAccountValueChanged")
                        .DataSource(new JS("purchasePage.accountDataSource"))
                )
                <small id="account-balance-note" class="purchase-balance-note">بلانس: 0 (صفر)</small>
            </div>
        </div>

        
        <div class="col-12 col-lg-4">
            <div class="purchase-field purchase-field-readonly">
                <label class="purchase-label">موبایل شمېره</label>
                @(
                    Html.DevExtreme().TextBox()
                        .ID("account-phone")
                        .ReadOnly(true)
                )
            </div>
        </div>

        <div class="col-12 col-lg-4">
            <div class="purchase-field purchase-field-readonly">
                <label class="purchase-label">ادرس</label>
                @(
                    Html.DevExtreme().TextBox()
                        .ID("account-address")
                        .ReadOnly(true)
                )
            </div>
        </div>
        
        <div class="col-12 col-lg-4">
            <div class="purchase-field">
                <label class="purchase-label">تجري/بانک</label>
                @(
                    Html.DevExtreme().SelectBox()
                        .ID("treasure-selector")
                        .ValueExpr("AccountID")
                        .DisplayExpr(new JS("purchasePage.accountDisplayExpr"))
                        .SearchEnabled(true)
                        .ShowClearButton(true)
                        .Placeholder("حساب انتخاب کړئ...")
                        .OnSelectionChanged("purchasePage.onTreasureSelectionChanged")
                        .DataSource(new JS("purchasePage.treasureDataSource"))
                )
                <small id="treasure-balance-note" class="purchase-balance-note">بلانس: 0 (صفر)</small>
            </div>
        </div>
        
        <div class="col-12 col-lg-4">
            <div class="purchase-field">
                <label class="purchase-label">اسعار</label>
                @(
                    Html.DevExtreme().SelectBox()
                        .ID("currency-selector")
                        .ValueExpr("ID")
                        .DisplayExpr("CurrencyName")
                        .SearchEnabled(true)
                        .ShowClearButton(true)
                        
                        .Placeholder("اسعار انتخاب کړئ...")
                        .OnValueChanged("purchasePage.onCurrencyChanged")
                        .DataSource(new JS("purchasePage.currencyDataSource"))
                )
            </div>
        </div>
        
        <div class="col-12 col-lg-4">
            <div class="purchase-field purchase-field-readonly">
                <label class="purchase-label">نېټه</label>
                @(
                    Html.DevExtreme().DateBox()
                    .ID("purchase-date")
                    .ReadOnly(true)
                    .Value(DateTime.Now)
                )
            </div>
        </div>

        <div class="col-12 col-lg-4">
            <div class="purchase-field purchase-field-readonly">
                <label class="purchase-label">مجموعه</label>
                @(
                    Html.DevExtreme().NumberBox()
                    .ID("purchase-total")
                    .Placeholder("مجموعه...")
                    .Min(0)
                    .Format("#,##0.###")
                    .ReadOnly(true)
                    .ShowSpinButtons(true)
                )
            </div>
        </div>

        <div class="col-12 col-lg-4">
            <div class="purchase-field purchase-field-readonly">
                <label class="purchase-label">رسید</label>
                @(
                    Html.DevExtreme().NumberBox()
                    .ID("purchase-received")
                    .Placeholder("رسید...")
                    .Min(0)
                    .Format("#,##0.###")
                    .ShowSpinButtons(true)
                    .OnValueChanged("purchasePage.onReceivedAmountChanged")
                )
            </div>
        </div>

        <div class="col-12 col-lg-4">
            <div class="purchase-field purchase-field-readonly">
                <label class="purchase-label">باقي</label>
                @(
                    Html.DevExtreme().NumberBox()
                    .ID("purchase-remaining")
                    .Placeholder("باقي...")
                    .Format("#,##0.###")
                    .ReadOnly(true)
                )
            </div>
        </div>

        <div class="col-12 col-lg-4">
            <div class="purchase-field">
                <label class="purchase-label">ملاحظات</label>
                @(
                    Html.DevExtreme().TextArea()
                    .ID("purchase-notes")
                    .Placeholder("ملاحظات...")
                )
            </div>
        </div>

        <div class="col-12 col-lg-4">
            <div class="purchase-field purchase-field-readonly">
                <label class="purchase-label">مجموعه، رسید او باقي په تورو</label>
                @(
                    Html.DevExtreme().TextArea()
                    .ID("account-balance-words")
                    .ReadOnly(true)
                    .Height(78)
                )
            </div>
        </div>
    </div>
</div>

<div class="dx-card px-4 py-3 mb-3">
    <div class="row g-3 align-items-end">
        @(
            Html.DevExtreme().DataGrid()
            .ID("purchase-details")
            .DataSource(new JS("purchasePage.purchaseDetailsData"))
            .KeyExpr("RowID")
            .ShowBorders(true)
            .RowAlternationEnabled(true)
            .ColumnAutoWidth(true)
            .Paging(p => p.Enabled(false))
            .Editing(e => e
                .Mode(GridEditMode.Cell)
                .AllowAdding(true)
                .AllowUpdating(true)
                .AllowDeleting(true)
                .UseIcons(true)
            )
            .OnInitNewRow("purchasePage.onPurchaseGridInitNewRow")
            .OnEditorPreparing("purchasePage.onPurchaseGridEditorPreparing")
            .OnRowRemoved("purchasePage.onPurchaseGridRowRemoved")
            .Columns(columns =>
            {
                columns.Add()
                    .DataField("ItemID")
                    .Caption("جنس")
                    .Lookup(l => l
                        .DataSource(new JS("purchasePage.itemLookupDataSource"))
                        .ValueExpr("ID")
                        .DisplayExpr("NativeName")
                    )
                    .CalculateDisplayValue(new JS("purchasePage.getItemDisplayText"))
                    .ValidationRules(r => r.AddRequired().Message("جنس ضروري دی."));

                columns.Add()
                    .DataField("UnitConversionID")
                    .Caption("واحد")
                    .Lookup(l => l
                        .DataSource(new JS("purchasePage.unitLookupDataSource"))
                        .ValueExpr("UnitConversionID")
                        .DisplayExpr("UnitName")
                    )
                    .CalculateDisplayValue(new JS("purchasePage.getUnitDisplayText"))
                    .ValidationRules(r => r.AddRequired().Message("واحد ضروري دی."));

                columns.Add()
                    .DataField("Quantity")
                    .Caption("مقدار")
                    .DataType(GridColumnDataType.Number)
                    .Format("#,##0.###")
                    .ValidationRules(r =>
                    {
                        r.AddRequired().Message("مقدار ضروري دی.");
                        r.AddRange().Min(0.001).Message("مقدار باید له صفر څخه زیات وي.");
                    });

                columns.Add()
                    .DataField("UnitPrice")
                    .Caption("في قیمت")
                    .DataType(GridColumnDataType.Number)
                    .Format("#,##0.###")
                    .ValidationRules(r =>
                    {
                        r.AddRequired().Message("قیمت ضروري دی.");
                    });

                columns.Add()
                    .DataField("TotalPrice")
                    .Caption("مجموعه قیمت")
                    .DataType(GridColumnDataType.Number)
                    .Format("#,##0.###");

                
                columns.Add()
                    .DataField("WarehouseID")
                    .Caption("ګدام")
                    .Lookup(l => l
                        .DataSource(new JS("purchasePage.warehouseLookupDataSource"))
                        .ValueExpr("ID")
                        .DisplayExpr("Name")
                    )
                    .CalculateDisplayValue(new JS("purchasePage.getWarehouseDisplayText"))
                    .ValidationRules(r => r.AddRequired().Message("ګدام ضروري دی."));

                columns.Add()
                    .DataField("Remarks")
                    .Caption("یادښت");
            })

            .Summary(summary => summary
                .TotalItems(items =>
                {
                    items.Add()
                        .Column("ItemID")
                        .SummaryType(SummaryType.Count)
                        .DisplayFormat("ټول قطارونه: {0}");

                    items.Add()
                        .Column("UnitPrice")
                        .SummaryType(SummaryType.Sum)
                        .DisplayFormat("مجموعه: {0}");

                        
                    items.Add()
                        .Column("TotalPrice")
                        .SummaryType(SummaryType.Sum)
                        .DisplayFormat("مجموعه: {0}");

                })
            )
        )
    </div>
</div>

<div id="pending-po-popup"></div>

<script>
    var purchasePage = (function () {
        var strictFullPaymentAccountTypeId = 10;

        var selectedPurchaseOrderId = null;
        var purchaseDetailsData = [];
        var purchaseRowCounter = 1;
        var unitOptionsByItemId = {};
        var activeItemsCache = [];
        var activeItemNameById = {};
        var activeWarehousesCache = [];
        var activeWarehouseNameById = {};
        var activeCurrenciesCache = [];
        var currencyExchangeRows = [];
        var mainCurrencyId = 0;
        var currentPriceCurrencyId = 0;
        var pendingOrdersPopup = null;
        var currentAccountBalanceValue = null;
        var currentTreasureBalanceValue = null;

        var accountDataSource = new DevExpress.data.DataSource({
            store: DevExpress.data.AspNet.createStore({
                key: "AccountID",
                loadUrl: '@Url.Content("~/api/Accounts")',
                loadParams: { types: "3,5, 10" }
            }),
            paginate: true,
            pageSize: 200
        });

        var activeItemsDataSource = new DevExpress.data.DataSource({
            store: DevExpress.data.AspNet.createStore({
                key: "ID",
                loadUrl: '@Url.Content("~/api/Items")'
            }),
            paginate: true,
            pageSize: 200
        });

        var itemLookupDataSource = new DevExpress.data.DataSource({
            store: DevExpress.data.AspNet.createStore({
                key: "ID",
                loadUrl: '@Url.Content("~/api/Items")'
            }),
            filter: ["IsActive", "=", true],
            paginate: true,
            pageSize: 200
        });

        var activeWarehousesDataSource = new DevExpress.data.DataSource({
            store: DevExpress.data.AspNet.createStore({
                key: "ID",
                loadUrl: '@Url.Content("~/api/Warehouses/Active")'
            }),
            paginate: true,
            pageSize: 200
        });

        var warehouseLookupDataSource = new DevExpress.data.DataSource({
            store: DevExpress.data.AspNet.createStore({
                key: "ID",
                loadUrl: '@Url.Content("~/api/Warehouses/Active")'
            }),
            paginate: true,
            pageSize: 200
        });

        function unitLookupDataSource(options) {
            var rowData = options && options.data ? options.data : null;
            var itemId = rowData && rowData.ItemID ? rowData.ItemID : 0;

            return {
                store: new DevExpress.data.CustomStore({
                    key: "UnitConversionID",
                    loadMode: "raw",
                    load: function () {
                        if (!itemId) return [];

                        return loadUnitOptionsForItem(itemId).then(function (options) {
                            if (rowData) rowData.UnitOptions = Array.isArray(options) ? options : [];
                            return rowData && Array.isArray(rowData.UnitOptions) ? rowData.UnitOptions : [];
                        });
                    },
                    byKey: function (key) {
                        if (!itemId || key === null || key === undefined || key === "") return null;

                        return loadUnitOptionsForItem(itemId).then(function (options) {
                            var rows = Array.isArray(options) ? options : [];
                            if (rowData) rowData.UnitOptions = rows;

                            for (var i = 0; i < rows.length; i++) {
                                if (rows[i] && rows[i].UnitConversionID === key) {
                                    return rows[i];
                                }
                            }

                            return null;
                        });
                    }
                })
            };
        }

        function normalizeDxLoadResult(result) {
            if (Array.isArray(result)) return result;
            if (result && Array.isArray(result.data)) return result.data;
            return [];
        }

        function refreshActiveItemsCache() {
            return activeItemsDataSource.load().then(function (result) {
                var allRows = normalizeDxLoadResult(result);
                activeItemsCache = allRows.filter(function (row) { return row && row.IsActive; });
                activeItemNameById = {};

                for (var i = 0; i < activeItemsCache.length; i++) {
                    var item = activeItemsCache[i];
                    if (item && item.ID) activeItemNameById[item.ID] = item.NativeName || "";
                }

                return activeItemsCache;
            });
        }

        function refreshActiveWarehousesCache() {
            return activeWarehousesDataSource.load().then(function (result) {
                var allRows = normalizeDxLoadResult(result);
                activeWarehousesCache = allRows.filter(function (row) { return row && row.IsActive; });
                activeWarehouseNameById = {};

                for (var i = 0; i < activeWarehousesCache.length; i++) {
                    var warehouse = activeWarehousesCache[i];
                    if (warehouse && warehouse.ID) activeWarehouseNameById[warehouse.ID] = warehouse.Name || "";
                }

                return activeWarehousesCache;
            });
        }

        function refreshCurrencyCache() {
            return currencyDataSource.load().then(function (result) {
                activeCurrenciesCache = normalizeDxLoadResult(result).filter(function (row) { return row && row.IsActive; });
                mainCurrencyId = 0;

                for (var i = 0; i < activeCurrenciesCache.length; i++) {
                    if (activeCurrenciesCache[i] && activeCurrenciesCache[i].IsMainCurrency) {
                        mainCurrencyId = Number(activeCurrenciesCache[i].ID || 0);
                        break;
                    }
                }

                return activeCurrenciesCache;
            });
        }

        function loadCurrencyExchangeRows() {
            return $.getJSON("/api/CurrencyExchange")
                .then(function (result) {
                    currencyExchangeRows = normalizeDxLoadResult(result).map(function (item) {
                        return {
                            SubCurrencyID: Number(item && item.SubCurrencyID ? item.SubCurrencyID : 0),
                            ExchangeRate: Number(item && item.ExchangeRate ? item.ExchangeRate : 0)
                        };
                    });

                    return currencyExchangeRows;
                }, function () {
                    currencyExchangeRows = [];
                    return [];
                });
        }

        function getCurrencyExchangeBySubCurrency(currencyId) {
            for (var i = 0; i < currencyExchangeRows.length; i++) {
                var row = currencyExchangeRows[i];
                if (Number(row && row.SubCurrencyID ? row.SubCurrencyID : 0) === Number(currencyId || 0)) {
                    return row;
                }
            }

            return null;
        }

        function getCurrencyStoredExchangeRate(currencyId) {
            var normalizedCurrencyId = Number(currencyId || 0);
            if (!normalizedCurrencyId) return 0;
            if (normalizedCurrencyId === Number(mainCurrencyId || 0)) return 1;

            var exchangeRow = getCurrencyExchangeBySubCurrency(normalizedCurrencyId);
            var rate = Number(exchangeRow && exchangeRow.ExchangeRate ? exchangeRow.ExchangeRate : 0);
            return rate > 0 ? rate : 0;
        }

        function convertAmountBetweenCurrencies(amount, fromCurrencyId, toCurrencyId) {
            var numericAmount = Number(amount);
            var normalizedFromCurrencyId = Number(fromCurrencyId || 0);
            var normalizedToCurrencyId = Number(toCurrencyId || 0);

            if (!Number.isFinite(numericAmount)) return amount;
            if (!normalizedFromCurrencyId || !normalizedToCurrencyId || normalizedFromCurrencyId === normalizedToCurrencyId) {
                return numericAmount;
            }

            var fromRate = getCurrencyStoredExchangeRate(normalizedFromCurrencyId);
            var toRate = getCurrencyStoredExchangeRate(normalizedToCurrencyId);
            if (fromRate <= 0 || toRate <= 0) return numericAmount;

            return numericAmount * toRate / fromRate;
        }

        function convertGridPricesToCurrency(fromCurrencyId, toCurrencyId) {
            var normalizedFromCurrencyId = Number(fromCurrencyId || 0);
            var normalizedToCurrencyId = Number(toCurrencyId || 0);

            if (!normalizedFromCurrencyId || !normalizedToCurrencyId || normalizedFromCurrencyId === normalizedToCurrencyId) {
                currentPriceCurrencyId = normalizedToCurrencyId;
                return;
            }

            var rows = getPurchaseGridRows();
            for (var i = 0; i < rows.length; i++) {
                var row = rows[i];
                if (!row) continue;

                if (row.UnitPrice !== null && row.UnitPrice !== undefined && row.UnitPrice !== "") {
                    row.UnitPrice = convertAmountBetweenCurrencies(row.UnitPrice, normalizedFromCurrencyId, normalizedToCurrencyId);
                }

                if (row.PurchaseUnitPrice !== null && row.PurchaseUnitPrice !== undefined && row.PurchaseUnitPrice !== "") {
                    row.PurchaseUnitPrice = convertAmountBetweenCurrencies(row.PurchaseUnitPrice, normalizedFromCurrencyId, normalizedToCurrencyId);
                }

                row.TotalPrice = row.Quantity !== null && row.Quantity !== undefined && row.UnitPrice !== null && row.UnitPrice !== undefined
                    ? Number(row.Quantity) * Number(row.UnitPrice)
                    : null;
                row.Profit = row.Quantity !== null && row.Quantity !== undefined && row.UnitPrice !== null && row.UnitPrice !== undefined && row.PurchaseUnitPrice !== null && row.PurchaseUnitPrice !== undefined
                    ? (Number(row.UnitPrice) - Number(row.PurchaseUnitPrice)) * Number(row.Quantity)
                    : 0;
            }

            var grid = getPurchaseGrid();
            if (grid) grid.refresh();

            currentPriceCurrencyId = normalizedToCurrencyId;
            updatePurchaseTotal();
        }

        function loadUnitOptionsForItem(itemId) {
            if (!itemId) return $.Deferred().resolve([]).promise();
            if (unitOptionsByItemId[itemId]) return $.Deferred().resolve(unitOptionsByItemId[itemId]).promise();

            return $.getJSON("/api/Items/" + itemId + "/InitialStock/UnitOptions")
                .then(function (options) {
                    var rows = Array.isArray(options) ? options : [];
                    unitOptionsByItemId[itemId] = rows;
                    return rows;
                }, function () {
                    return [];
                });
        }

        function findMatchingUnitConversionId(options, unitConversionId) {
            if (!Array.isArray(options) || unitConversionId === null || unitConversionId === undefined || unitConversionId === "") {
                return null;
            }

            for (var i = 0; i < options.length; i++) {
                var option = options[i];
                if (option && option.UnitConversionID === unitConversionId) {
                    return option.UnitConversionID;
                }
            }

            return null;
        }

        function getPreferredUnitConversionId(options, preferredUnitConversionId) {
            var matchingId = findMatchingUnitConversionId(options, preferredUnitConversionId);
            if (matchingId !== null) return matchingId;

            if (!Array.isArray(options) || options.length === 0) return null;

            var firstOption = options[0];
            return firstOption ? firstOption.UnitConversionID : null;
        }

        function syncRowUnitOptions(grid, rowIndex, rowData, options, preferredUnitConversionId) {
            var normalizedOptions = Array.isArray(options) ? options : [];
            var nextUnitConversionId = getPreferredUnitConversionId(normalizedOptions, preferredUnitConversionId);

            if (rowData) {
                rowData.UnitOptions = normalizedOptions;
                rowData.UnitConversionID = nextUnitConversionId;
            }

            if (grid && rowIndex !== undefined && rowIndex !== null) {
                grid.cellValue(rowIndex, "UnitConversionID", nextUnitConversionId);
                grid.repaintRows([rowIndex]);
            }

            return nextUnitConversionId;
        }

        function getSelectedSaleDate() {
            var dateInstance = $("#purchase-date").dxDateBox("instance");
            return dateInstance ? dateInstance.option("value") : null;
        }

        function loadItemPricing(itemId, unitConversionId) {
            if (!itemId) {
                return $.Deferred().resolve({
                    SaleUnitPrice: null,
                    PurchaseUnitPrice: null
                }).promise();
            }

            var requestData = {
                unitConversionId: unitConversionId
            };
            var saleDate = getSelectedSaleDate();
            if (saleDate) {
                requestData.saleDate = saleDate.toISOString ? saleDate.toISOString() : saleDate;
            }

            return $.getJSON("/api/Sales/item-pricing/" + itemId, requestData)
                .then(function (response) {
                    return response || {};
                }, function () {
                    return {
                        SaleUnitPrice: null,
                        PurchaseUnitPrice: null
                    };
                });
        }

        function updateRowCalculatedValues(grid, rowIndex, rowData) {
            var quantity = Number(grid.cellValue(rowIndex, "Quantity") || 0);
            var unitPrice = Number(grid.cellValue(rowIndex, "UnitPrice") || 0);
            var total = quantity * unitPrice;
            var purchaseUnitPrice = rowData && rowData.PurchaseUnitPrice !== null && rowData.PurchaseUnitPrice !== undefined
                ? Number(rowData.PurchaseUnitPrice)
                : null;
            var profit = purchaseUnitPrice === null
                ? 0
                : (unitPrice - purchaseUnitPrice) * quantity;

            grid.cellValue(rowIndex, "TotalPrice", total);
            if (rowData) {
                rowData.TotalPrice = total;
                rowData.Profit = profit;
            }

            updatePurchaseTotal();
        }

        function applyItemPricing(grid, rowIndex, rowData, pricing, applySaleUnitPrice) {
            var resolvedPricing = pricing || {};
            var saleUnitPrice = resolvedPricing.SaleUnitPrice !== null && resolvedPricing.SaleUnitPrice !== undefined
                ? Number(resolvedPricing.SaleUnitPrice)
                : null;
            var purchaseUnitPrice = resolvedPricing.PurchaseUnitPrice !== null && resolvedPricing.PurchaseUnitPrice !== undefined
                ? Number(resolvedPricing.PurchaseUnitPrice)
                : null;

            if (rowData) {
                rowData.PurchaseUnitPrice = purchaseUnitPrice;
            }

            if (applySaleUnitPrice) {
                grid.cellValue(rowIndex, "UnitPrice", saleUnitPrice);
                if (rowData) {
                    rowData.UnitPrice = saleUnitPrice;
                }
            }

            updateRowCalculatedValues(grid, rowIndex, rowData);
        }

        function prepareUnitConversionEditor(editorOptions, rowData) {
            var itemId = rowData && rowData.ItemID ? rowData.ItemID : null;
            var dataSourceConfig = unitLookupDataSource({ data: rowData || {} });

            editorOptions.dataSource = dataSourceConfig;
            editorOptions.displayExpr = "UnitName";
            editorOptions.valueExpr = "UnitConversionID";
            editorOptions.searchEnabled = true;
            editorOptions.showClearButton = true;
            editorOptions.disabled = !itemId;
            editorOptions.placeholder = itemId ? "واحد وټاکئ..." : "لومړی جنس وټاکئ...";
        }

        function getItemDisplayText(rowData) {
            if (!rowData || !rowData.ItemID) return "";
            return activeItemNameById[rowData.ItemID] || rowData.ItemID;
        }

        function getUnitDisplayText(rowData) {
            if (!rowData || rowData.UnitConversionID === null || rowData.UnitConversionID === undefined) return "";

            var options = Array.isArray(rowData.UnitOptions) ? rowData.UnitOptions : [];
            for (var i = 0; i < options.length; i++) {
                var unit = options[i];
                if (unit && unit.UnitConversionID === rowData.UnitConversionID) {
                    return unit.UnitName || "";
                }
            }

            return rowData.UnitConversionID;
        }

