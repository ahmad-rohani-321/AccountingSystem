        function buildPurchasePayload() {
            var purchaseNo = getNumberBoxValue("#purchase-no");
            var accountId = getSelectBoxValue("#account-selector");
            var currencyId = getSelectBoxValue("#currency-selector");
            var dateInstance = $("#purchase-date").dxDateBox("instance");
            var notesInstance = $("#purchase-notes").dxTextArea("instance");
            var rows = getPurchaseGridRows();

            return {
                OrderID: selectedPurchaseOrderId,
                SaleNo: purchaseNo,
                AccountID: accountId,
                TreasureAccountID: getSelectBoxValue("#treasure-selector") || null,
                IsHolded: isHoldedSelected(),
                CurrencyID: currencyId,
                SaleDate: dateInstance ? dateInstance.option("value") : null,
                TotalAmount: getNumberBoxValue("#purchase-total"),
                ReceivedAmount: getNumberBoxValue("#purchase-received"),
                RemainingAmount: getNumberBoxValue("#purchase-remaining"),
                Remarks: notesInstance ? (notesInstance.option("value") || "") : "",
                Details: rows.map(function (row) {
                    var quantity = Number(row && row.Quantity ? row.Quantity : 0);
                    var unitPrice = Number(row && row.UnitPrice ? row.UnitPrice : 0);
                    return {
                        ItemID: row && row.ItemID ? row.ItemID : 0,
                        UnitConversionID: row && row.UnitConversionID !== null && row.UnitConversionID !== undefined
                            ? row.UnitConversionID
                            : null,
                        Quantity: quantity,
                        UnitPrice: unitPrice,
                        TotalPrice: row && row.TotalPrice !== null && row.TotalPrice !== undefined
                            ? Number(row.TotalPrice || 0)
                            : quantity * unitPrice,
                        WarehouseID: row && row.WarehouseID ? row.WarehouseID : 0,
                        Remarks: row && row.Remarks ? row.Remarks : ""
                    };
                })
            };
        }

        function extractServerError(xhr) {
            if (xhr && xhr.responseJSON && xhr.responseJSON.Message) return xhr.responseJSON.Message;
            if (xhr && xhr.responseText) return xhr.responseText;
            return "د ثبت پر مهال ستونزه رامنځته شوه.";
        }

