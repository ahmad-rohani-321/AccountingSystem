        function useVisibleEditorValidationMessages() {
            var editorConfigs = [
                { selector: "#purchase-no", widget: "dxNumberBox" },
                { selector: "#account-selector", widget: "dxSelectBox" },
                { selector: "#currency-selector", widget: "dxSelectBox" },
                { selector: "#purchase-date", widget: "dxDateBox" },
                { selector: "#treasure-selector", widget: "dxSelectBox" },
                { selector: "#purchase-received", widget: "dxNumberBox" }
            ];

            for (var i = 0; i < editorConfigs.length; i++) {
                var config = editorConfigs[i];
                var editor = $(config.selector)[config.widget]("instance");
                if (!editor) continue;

                editor.option({
                    validationMessageMode: "always",
                    validationMessagePosition: "bottom"
                });
            }
        }

