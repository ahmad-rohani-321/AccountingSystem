                    $.ajax({
                        url: "/api/Sales",
                        method: "POST",
                        contentType: "application/json; charset=utf-8",
                        data: JSON.stringify(buildPurchasePayload())
                    }).done(function (response) {
                        DevExpress.ui.notify(response && response.Message ? response.Message : "فروش په بریالیتوب ثبت شو.", "success", 2200);
                        onClearFormClick();
                    }).fail(function (xhr) {
                        DevExpress.ui.notify(extractServerError(xhr), "error", 3500);
                    });
                });
            });
        }

        function loadPurchaseOrderIntoForm(orderId) {
            if (!orderId) return;

            $.getJSON("/api/SaleOrders/" + orderId)
                .done(function (response) {
                    selectedPurchaseOrderId = orderId;
                    var accountInstance = $("#account-selector").dxSelectBox("instance");
                    var dateInstance = $("#purchase-date").dxDateBox("instance");
                    var notesInstance = $("#purchase-notes").dxTextArea("instance");

                    if (accountInstance) accountInstance.option("value", response && response.AccountID ? response.AccountID : null);
                    if (dateInstance) dateInstance.option("value", response && response.DueDate ? new Date(response.DueDate) : new Date());
                    if (notesInstance) notesInstance.option("value", response && response.Remarks ? response.Remarks : "");

                    purchaseDetailsData.length = 0;
                    purchaseRowCounter = 1;

                    var details = response && Array.isArray(response.Details) ? response.Details : [];
                    for (var i = 0; i < details.length; i++) {
                        var row = details[i];
                        purchaseDetailsData.push({
                            RowID: purchaseRowCounter++,
                            ItemID: row.ItemID || null,
                            UnitConversionID: row.UnitConversionID !== undefined && row.UnitConversionID !== null
                                ? row.UnitConversionID
                                : null,
                            Quantity: row.Quantity || null,
                            UnitPrice: null,
                            TotalPrice: null,
                            PurchaseUnitPrice: null,
                            Profit: 0,
                            WarehouseID: null,
                            Remarks: row.Remarks || "",
                            UnitOptions: []
                        });
                    }

                    var grid = getPurchaseGrid();
                    if (grid) {
                        grid.cancelEditData();
                        grid.refresh();
                    }

                    var unitLoaders = [];
                    for (var j = 0; j < purchaseDetailsData.length; j++) {
                        (function (targetRow) {
                            if (!targetRow.ItemID) return;
                            var loader = loadUnitOptionsForItem(targetRow.ItemID).then(function (options) {
                                targetRow.UnitConversionID = getPreferredUnitConversionId(options, targetRow.UnitConversionID);
                                targetRow.UnitOptions = Array.isArray(options) ? options : [];

                                return loadItemPricing(targetRow.ItemID, targetRow.UnitConversionID).then(function (pricing) {
                                    targetRow.UnitPrice = pricing && pricing.SaleUnitPrice !== null && pricing.SaleUnitPrice !== undefined
                                        ? Number(pricing.SaleUnitPrice)
                                        : null;
                                    targetRow.PurchaseUnitPrice = pricing && pricing.PurchaseUnitPrice !== null && pricing.PurchaseUnitPrice !== undefined
                                        ? Number(pricing.PurchaseUnitPrice)
                                        : null;
                                    targetRow.TotalPrice = targetRow.Quantity && targetRow.UnitPrice !== null
                                        ? Number(targetRow.Quantity) * Number(targetRow.UnitPrice)
                                        : null;
                                    targetRow.Profit = targetRow.Quantity && targetRow.UnitPrice !== null && targetRow.PurchaseUnitPrice !== null
                                        ? (Number(targetRow.UnitPrice) - Number(targetRow.PurchaseUnitPrice)) * Number(targetRow.Quantity)
                                        : 0;
                                });
                            });
                            unitLoaders.push(loader);
                        })(purchaseDetailsData[j]);
                    }

                    if (unitLoaders.length > 0) {
                        $.when.apply($, unitLoaders).always(function () {
                            var purchaseGrid = getPurchaseGrid();
                            if (purchaseGrid) purchaseGrid.refresh();
                            updatePurchaseTotal();
                        });
                    } else {
                        updatePurchaseTotal();
                    }
                    syncAccountContactById(response && response.AccountID ? response.AccountID : null);
                    refreshAllBalanceLabels();
                })
                .fail(function () {
                    DevExpress.ui.notify("آرډر ونه موندل شو.", "error", 2800);
                });
        }

        function onPendingOrderSelectClick(e) {
            var rowData = e && e.row ? e.row.data : null;
            if (!rowData || !rowData.ID) return;

            loadPurchaseOrderIntoForm(rowData.ID);
            if (pendingOrdersPopup) pendingOrdersPopup.hide();
        }

        function ensurePendingOrdersPopup() {
            if (pendingOrdersPopup) return pendingOrdersPopup;

            pendingOrdersPopup = $("#pending-po-popup").dxPopup({
                title: "ناتکمیل فروش آرډرونه",
                showTitle: true,
                visible: false,
                width: 980,
                maxWidth: "95vw",
                height: "auto",
                maxHeight: "88vh",
                dragEnabled: true,
                hideOnOutsideClick: true,
                contentTemplate: function (contentElement) {
                    var wrapper = $("<div id='pending-po-grid' style='min-height:60vh;'></div>");
                    contentElement.append(wrapper);

                    wrapper.dxDataGrid({
                        dataSource: pendingPurchaseOrdersDataSource,
                        remoteOperations: true,
                        showBorders: true,
                        rowAlternationEnabled: true,
                        columnAutoWidth: true,
                        searchPanel: { visible: true, placeholder: "پلټنه..." },
                        paging: { pageSize: 12 },
                        pager: {
                            showPageSizeSelector: true,
                            allowedPageSizes: [12, 24, 50],
                            showInfo: true
                        },
                        columns: [
                            { dataField: "ID", caption: "آرډر #" },
                            { dataField: "AccountName", caption: "حساب" },
                            { dataField: "DueDate", caption: "د تادیې نېټه", dataType: "date", format: "yyyy-MM-dd" },
                            { dataField: "Remarks", caption: "ملاحظات" },
                            { dataField: "CreationDate", caption: "نېټه", dataType: "datetime", format: "yyyy-MM-dd HH:mm" },
                            {
                                type: "buttons",
                                caption: "عملیات",
                                width: 120,
                                buttons: [
                                    {
                                        hint: "انتخاب",
                                        icon: "fa-solid fa-check",
                                        onClick: onPendingOrderSelectClick
                                    }
                                ]
                            }
                        ]
                    });
                },
                onShown: function () {
                    var grid = $("#pending-po-grid").dxDataGrid("instance");
                    if (grid && grid.getDataSource()) {
                        grid.getDataSource().reload();
                    }
                }
            }).dxPopup("instance");

            return pendingOrdersPopup;
        }

        function onSelectOrderClick() {
            ensurePendingOrdersPopup().show();
        }

        function setDefaultCurrencyToFirst() {
            var currencyInstance = $("#currency-selector").dxSelectBox("instance");
            if (!currencyInstance) return;

            if (currencyInstance.option("value")) return;

            currencyDataSource.load().then(function (result) {
                var rows = normalizeDxLoadResult(result);
                if (!rows.length) return;

                var firstCurrency = rows[0];
                if (firstCurrency && firstCurrency.ID) {
                    currencyInstance.option("value", firstCurrency.ID);
                }
            });
        }

        function onClearFormClick() {
            var purchaseNoInstance = $("#purchase-no").dxNumberBox("instance");
            var accountInstance = $("#account-selector").dxSelectBox("instance");
            var treasureInstance = $("#treasure-selector").dxSelectBox("instance");
            var currencyInstance = $("#currency-selector").dxSelectBox("instance");
            var dateInstance = $("#purchase-date").dxDateBox("instance");
            var notesInstance = $("#purchase-notes").dxTextArea("instance");
            var receivedInstance = $("#purchase-received").dxNumberBox("instance");
            var remainingInstance = $("#purchase-remaining").dxNumberBox("instance");
            var isHoldedInstance = $("#is-holded").dxCheckBox("instance");
            var purchaseGrid = $("#purchase-details").dxDataGrid("instance");

            if (purchaseNoInstance) purchaseNoInstance.option("value", null);
            if (accountInstance) accountInstance.option("value", null);
            if (treasureInstance) treasureInstance.option("value", null);
            if (currencyInstance) currencyInstance.option("value", null);
            if (dateInstance) dateInstance.option("value", new Date());
            if (notesInstance) notesInstance.option("value", "");
            if (receivedInstance) receivedInstance.option("value", null);
            if (remainingInstance) remainingInstance.option("value", 0);
            if (isHoldedInstance) isHoldedInstance.option("value", false);
            selectedPurchaseOrderId = null;
            currentPriceCurrencyId = 0;

            setAccountContactFields(null);
            currentAccountBalanceValue = null;
            currentTreasureBalanceValue = null;
            resetProjectedBalanceLabels();

            purchaseDetailsData.length = 0;
            purchaseRowCounter = 1;
            unitOptionsByItemId = {};

            if (purchaseGrid) {
                purchaseGrid.cancelEditData();
                purchaseGrid.option("dataSource", purchaseDetailsData);
                purchaseGrid.refresh();
            }

            updatePurchaseTotal();

            syncHoldStatePresentation();
            setDefaultCurrencyToFirst();
            refreshAllBalanceLabels();
            loadNextPurchaseNo();
            updatePurchaseAmountWords();
        }

        $(function () {
            var accountInstance = $("#account-selector").dxSelectBox("instance");
            var initialAccountId = accountInstance ? accountInstance.option("value") : null;
            syncAccountContactById(initialAccountId);
            setDefaultCurrencyToFirst();

            refreshAllBalanceLabels();
            updateRemainingAmount();
            updatePurchaseAmountWords();
            resetProjectedBalanceLabels();

            $("#purchase-no").dxValidator({
                validationRules: [
                    { type: "required", message: "د فروش شمېره له سرور څخه ضروري ده." }
                ]
            });

            $("#account-selector").dxValidator({
                validationRules: [
                    { type: "required", message: "حساب انتخاب کړئ." }
                ]
            });

            $("#currency-selector").dxValidator({
                validationRules: [
                    { type: "required", message: "اسعار انتخاب کړئ." }
                ]
            });

            $("#purchase-date").dxValidator({
                validationRules: [
                    { type: "required", message: "نېټه انتخاب کړئ." }
                ]
            });

            $("#treasure-selector").dxValidator({
                validationRules: [
                    {
                        type: "custom",
                        reevaluate: true,
                        message: "کله چې رسید داخل وي، تجري/بانک انتخاب کړئ.",
                        validationCallback: function () {
                            if (isHoldedSelected()) return true;
                            var receivedAmount = getNumberBoxValue("#purchase-received");
                            var treasureAccountId = getSelectBoxValue("#treasure-selector");
                            return receivedAmount <= 0 || treasureAccountId > 0;
                        }
                    }
                ]
            });

            $("#purchase-received").dxValidator({
                validationRules: [
                    {
                        type: "custom",
                        reevaluate: true,
                        message: "کله چې تجري/بانک انتخاب وي، رسید باید له صفر څخه زیات وي.",
                        validationCallback: function () {
                            if (isHoldedSelected()) return true;
                            var treasureAccountId = getSelectBoxValue("#treasure-selector");
                            var receivedAmount = getNumberBoxValue("#purchase-received");
                            return !treasureAccountId || receivedAmount > 0;
                        }
                    },
                    {
                        type: "custom",
                        reevaluate: true,
                        message: "رسید باید له مجموعې څخه زیات نه وي.",
                        validationCallback: function () {
                            return getNumberBoxValue("#purchase-received") <= getNumberBoxValue("#purchase-total");
                        }
                    },
                    {
                        type: "custom",
                        reevaluate: true,
                        message: "د حساب ټایپ 10 لپاره رسید باید له مجموعې سره مساوي وي.",
                        validationCallback: function () {
                            if (isHoldedSelected()) return true;
                            if (!isStrictFullPaymentAccountSelected()) return true;
                            return getNumberBoxValue("#purchase-received") === getNumberBoxValue("#purchase-total");
                        }
                    },
                    {
                        type: "async",
                        reevaluate: true,
                        message: "رسید مبلغ په دخل/بانک کې نه دی.",
                        validationCallback: function () {
                            if (isHoldedSelected()) {
                                return $.Deferred().resolve(true).promise();
                            }

                            var treasureAccountId = getSelectBoxValue("#treasure-selector");
                            var currencyId = getSelectBoxValue("#currency-selector");
                            var receivedAmount = getNumberBoxValue("#purchase-received");

                            if (!treasureAccountId || !currencyId || receivedAmount <= 0) {
                                return $.Deferred().resolve(true).promise();
                            }

                            return getTreasureBalance(treasureAccountId, currencyId)
                                .then(function (treasureBalance) {
                                    return receivedAmount <= Number(treasureBalance || 0);
                                }, function () {
                                    return false;
                                });
                        }
                    }
                ]
            });

            useVisibleEditorValidationMessages();
            syncHoldStatePresentation();
            syncSpecialAccountPaymentRule();

            $.when(refreshActiveItemsCache(), refreshActiveWarehousesCache(), refreshCurrencyCache(), loadCurrencyExchangeRows()).always(function () {
                loadNextPurchaseNo();

                var purchaseGrid = $("#purchase-details").dxDataGrid("instance");
                if (purchaseGrid) purchaseGrid.refresh();
            });
        });

        return {
            purchaseDetailsData: purchaseDetailsData,
            accountDataSource: accountDataSource,
            treasureDataSource: treasureDataSource,
            currencyDataSource: currencyDataSource,
            itemLookupDataSource: itemLookupDataSource,
            warehouseLookupDataSource: warehouseLookupDataSource,
            unitLookupDataSource: unitLookupDataSource,
            accountDisplayExpr: accountDisplayExpr,
            getItemDisplayText: getItemDisplayText,
            getUnitDisplayText: getUnitDisplayText,
            getWarehouseDisplayText: getWarehouseDisplayText,
            onPurchaseGridRowRemoved: onPurchaseGridRowRemoved,
            onPurchaseGridInitNewRow: onPurchaseGridInitNewRow,
            onPurchaseGridEditorPreparing: onPurchaseGridEditorPreparing,
            onAccountSelectionChanged: onAccountSelectionChanged,
            onAccountValueChanged: onAccountValueChanged,
            onTreasureSelectionChanged: onTreasureSelectionChanged,
            onIsHoldedChanged: onIsHoldedChanged,
            onCurrencyChanged: onCurrencyChanged,
            onReceivedAmountChanged: onReceivedAmountChanged,
            onSaveFormClick: onSaveFormClick,
            onClearFormClick: onClearFormClick,
            onSelectOrderClick: onSelectOrderClick
        };
    })();
</script>
