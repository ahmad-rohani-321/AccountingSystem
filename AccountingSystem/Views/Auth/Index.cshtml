@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>ننوتل</title>
    <link href="~/css/devextreme/dx.fluent.saas.light.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/Site.css" />
    <link rel="stylesheet" href="~/css/Auth.css" />

    <script src="~/js/devextreme/jquery.js"></script>
    <script src="~/js/devextreme/dx.all.js"></script>
    <script src="~/js/devextreme/aspnet/dx.aspnet.mvc.js"></script>
    <script src="~/js/devextreme/aspnet/dx.aspnet.data.js"></script>

</head>

<body>
    <div class="auth-page">
        <div class="auth-card dx-card">
            <h1 class="auth-title">سیسټم ته ننوتل</h1>

            <form class="auth-form" id="loginForm" method="post" action="@Url.Action("Index", "Auth")">
                @Html.AntiForgeryToken()

                 @if (!ViewData.ModelState.IsValid)
                 {
                     <div class="validation-summary validation-summary-errors" role="alert">
                         @foreach (var modelState in ViewData.ModelState.Values)
                         {
                             @foreach (var modelError in modelState.Errors)
                             {
                                <div>@modelError.ErrorMessage</div>
                            }
                        }
                    </div>
                }

                <div class="dx-field">
                    @(Html.DevExtreme().TextBox()
                                        .Name("UserName")
                                        .Placeholder("یوزر نوم")
                                        .Label("یوزر نوم")
                                        .ShowClearButton(true)
                                        .Width("100%")

                                        )
                </div>
                <div class="dx-field">
                    @(Html.DevExtreme().TextBox()
                                        .Name("Password")
                                        .Placeholder("پاسورډ")
                                        .Label("پاسورډ")
                                        .Mode(TextBoxMode.Password)
                                        .ShowClearButton(true)
                                        .Width("100%")
                                        )
                </div>
                <div class="dx-field auth-remember">
                    @(Html.DevExtreme().CheckBox()
                                        .Name("RememberMe")
                                        .Text("په یاد لرل")
                                        .Value(false)
                                        )
                </div>
                <div class="auth-actions">
                    @(Html.DevExtreme().Button()
                                        .Text("ننوتل")
                                        .Type(ButtonType.Default)
                                        .StylingMode(ButtonStylingMode.Contained)
                                        .UseSubmitBehavior(true)
                                        .Width("100%")
                                        )
                </div>
            </form>
        </div>
    </div>
    <script>
            DevExpress.config({
                rtlEnabled: true
            });
    </script>
    <script src="~/js/devextreme/localization/dx.messages.fa.js"></script>
</body>

</html>
