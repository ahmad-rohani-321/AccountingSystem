@{
    ViewData["Title"] = "نوی آرډر";
}

<div class="dx-card px-4 py-3 mb-3">
    <div class="d-flex gap-2 flex-wrap">
        @(
            Html.DevExtreme().Button()
                .ID("poSaveButton")
                .Text("ثبت")
                .Type(ButtonType.Success)
                .StylingMode(ButtonStylingMode.Contained)
                .Icon("fa-solid fa-floppy-disk")
                .OnClick("purchaseOrderPage.onSaveClick")
        )
        @(
            Html.DevExtreme().Button()
                .ID("poClearButton")
                .Text("فورم پاکول")
                .Type(ButtonType.Normal)
                .StylingMode(ButtonStylingMode.Outlined)
                .Icon("fa-solid fa-eraser")
                .OnClick("purchaseOrderPage.onClearClick")
        )
    </div>
</div>

<div class="dx-card px-4 py-3">
    <div class="row g-3 align-items-end">
        <div class="col-12 col-lg-4">
            <label class="form-label">حساب</label>
            @(
                Html.DevExtreme().SelectBox()
                    .ID("poAccountSelect")
                    .ValueExpr("AccountID")
                    .DisplayExpr(new JS("purchaseOrderPage.accountDisplayExpr"))
                    .SearchEnabled(true)
                    .ShowClearButton(true)
                    .Placeholder("حساب انتخاب کړئ...")
                    .OnSelectionChanged("purchaseOrderPage.onAccountChanged")
                    .DataSource(new JS("purchaseOrderPage.accountDataSource"))
            )
        </div>

        <div class="col-12 col-md-6 col-lg-4">
            <label class="form-label">لومړی موبایل</label>
            @(
                Html.DevExtreme().TextBox()
                    .ID("poFirstPhone")
                    .ReadOnly(true)
            )
        </div>

        <div class="col-12 col-md-6 col-lg-4">
            <label class="form-label">پته</label>
            @(
                Html.DevExtreme().TextBox()
                    .ID("poAddress")
                    .ReadOnly(true)
            )
        </div>

        <div class="col-12 col-md-6 col-lg-4">
            <label class="form-label">د تادیې نېټه</label>
            @(
                Html.DevExtreme().DateBox()
                    .ID("poDate")
                    .Type(DateBoxType.Date)
                    .Value(DateTime.Today)
                    .DisplayFormat("yyyy-MM-dd")
                    .ShowClearButton(true)
                    .TodayButtonText("نن")
                    .ShowDropDownButton(true)
            )
        </div>

        

        <div class="col-12 col-md-6 col-lg-4">
            <label class="form-label">ملاحظات</label>
            @(
                Html.DevExtreme().TextArea()
                    .ID("remarks")
            )
        </div>
    </div>
</div>

<div class="dx-card px-4 py-3 mt-3">
    @(
        Html.DevExtreme().DataGrid()
            .ID("poDetailsGrid")
            .DataSource(new JS("purchaseOrderPage.orderRows"))
            .KeyExpr("RowID")
            .ShowBorders(true)
            .RowAlternationEnabled(true)
            .ColumnAutoWidth(true)
            .Paging(p => p.Enabled(false))
            .Editing(e => e
                .Mode(GridEditMode.Cell)
                .AllowAdding(true)
                .AllowUpdating(true)
                .AllowDeleting(true)
                .UseIcons(true)
            )
            .OnInitNewRow("purchaseOrderPage.onOrderGridInitNewRow")
            .OnEditorPreparing("purchaseOrderPage.onOrderGridEditorPreparing")
            .Columns(columns =>
            {
                columns.Add()
                    .DataField("ItemID")
                    .Caption("جنس")
                    .CalculateDisplayValue(new JS("purchaseOrderPage.getItemDisplayText"))
                    .ValidationRules(r => r.AddRequired().Message("جنس ضروری دی."));

                columns.Add()
                    .DataField("UnitConversionID")
                    .Caption("واحد")
                    .CalculateDisplayValue(new JS("purchaseOrderPage.getUnitDisplayText"))
                    .ValidationRules(r => r.AddRequired().Message("واحد ضروری دی."));

                columns.Add()
                    .DataField("Quantity")
                    .Caption("مقدار")
                    .DataType(GridColumnDataType.Number)
                    .Format("#,##0.###")
                    .ValidationRules(r =>
                    {
                        r.AddRequired().Message("مقدار ضروری دی.");
                        r.AddRange().Min(0.001).Message("مقدار باید له صفر څخه زیات وي.");
                    });

                columns.Add()
                    .DataField("Remarks")
                    .Caption("یادښت");
            })
            .Summary(summary => summary
                .TotalItems(items =>
                {
                    items.Add()
                        .Column("ItemID")
                        .SummaryType(SummaryType.Count)
                        .DisplayFormat("ټول قطارونه: {0}")
                        .ShowInColumn("ItemID");
                })
            )
    )
</div>

<script>
    var purchaseOrderPage = (function () {
        var initialOrderId = @(((int?)ViewBag.OrderID).GetValueOrDefault(0));

        var accountDataSource = new DevExpress.data.DataSource({
            store: DevExpress.data.AspNet.createStore({
                key: "AccountID",
                loadUrl: '@Url.Content("~/api/Accounts")',
                loadParams: { types: "4,5" }
            }),
            paginate: true,
            pageSize: 200
        });

        var orderRows = [];
        var rowCounter = 1;
        var currentPurchaseOrderId = null;
        var unitOptionsByItemId = {};
        var activeItemsCache = [];
        var activeItemNameById = {};

        var activeItemsDataSource = new DevExpress.data.DataSource({
            store: DevExpress.data.AspNet.createStore({
                key: "ID",
                loadUrl: '@Url.Content("~/api/Items")'
            }),
            paginate: true,
            pageSize: 200
        });

        function setContactFields(account) {
            $("#poFirstPhone").dxTextBox("instance").option("value", account && account.FirstPhone ? account.FirstPhone : "");
            $("#poAddress").dxTextBox("instance").option("value", account && account.Address ? account.Address : "");
        }

        function accountDisplayExpr(item) {
            if (!item) return "";
            var code = item.Code ? (item.Code + " - ") : "";
            return code + (item.Name || "");
        }

        function onAccountChanged(e) {
            setContactFields(e && e.selectedItem ? e.selectedItem : null);
        }

        function normalizeDxLoadResult(result) {
            if (Array.isArray(result)) return result;
            if (result && Array.isArray(result.data)) return result.data;
            return [];
        }

        function refreshActiveItemsCache() {
            return activeItemsDataSource.load().then(function (result) {
                var allRows = normalizeDxLoadResult(result);
                activeItemsCache = allRows.filter(function (row) { return row && row.IsActive; });
                activeItemNameById = {};
                for (var i = 0; i < activeItemsCache.length; i++) {
                    var item = activeItemsCache[i];
                    if (item && item.ID) activeItemNameById[item.ID] = item.NativeName || "";
                }
                return activeItemsCache;
            });
        }

        function loadUnitOptionsForItem(itemId) {
            if (!itemId) return $.Deferred().resolve([]).promise();
            if (unitOptionsByItemId[itemId]) return $.Deferred().resolve(unitOptionsByItemId[itemId]).promise();

            return $.getJSON("/api/Items/" + itemId + "/InitialStock/UnitOptions")
                .then(function (options) {
                    var rows = Array.isArray(options) ? options : [];
                    unitOptionsByItemId[itemId] = rows;
                    return rows;
                }, function () {
                    return [];
                });
        }

        function getItemDisplayText(rowData) {
            if (!rowData || !rowData.ItemID) return "";
            return activeItemNameById[rowData.ItemID] || rowData.ItemID;
        }

        function getUnitDisplayText(rowData) {
            if (!rowData || rowData.UnitConversionID === null || rowData.UnitConversionID === undefined) return "";

            var options = Array.isArray(rowData.UnitOptions) ? rowData.UnitOptions : [];
            for (var i = 0; i < options.length; i++) {
                var unit = options[i];
                if (unit && unit.UnitConversionID === rowData.UnitConversionID) {
                    return unit.UnitName || "";
                }
            }

            return rowData.UnitConversionID;
        }

        function onOrderGridInitNewRow(e) {
            e.data.RowID = rowCounter++;
            e.data.ItemID = null;
            e.data.UnitConversionID = null;
            e.data.Quantity = null;
            e.data.Remarks = "";
            e.data.UnitOptions = [];
        }

        function onOrderGridEditorPreparing(e) {
            if (e.parentType !== "dataRow") return;

            if (e.dataField === "ItemID") {
                e.editorName = "dxSelectBox";
                e.editorOptions.dataSource = activeItemsCache;
                e.editorOptions.displayExpr = "NativeName";
                e.editorOptions.valueExpr = "ID";
                e.editorOptions.searchEnabled = true;
                e.editorOptions.showClearButton = true;

                var baseItemChanged = e.editorOptions.onValueChanged;
                e.editorOptions.onValueChanged = function (args) {
                    if (baseItemChanged) baseItemChanged(args);

                    var selectedItemId = args && args.value ? args.value : null;
                    var rowIndex = e.row.rowIndex;
                    var grid = e.component;
                    var rowData = e.row && e.row.data ? e.row.data : null;

                    grid.cellValue(rowIndex, "ItemID", selectedItemId);
                    grid.cellValue(rowIndex, "UnitConversionID", null);

                    if (rowData) rowData.UnitOptions = [];

                    if (!selectedItemId) {
                        grid.repaintRows([rowIndex]);
                        return;
                    }

                    loadUnitOptionsForItem(selectedItemId).then(function (options) {
                        if (rowData) rowData.UnitOptions = options;
                        if (options.length === 1) {
                            grid.cellValue(rowIndex, "UnitConversionID", options[0].UnitConversionID);
                        }
                        grid.repaintRows([rowIndex]);
                    });
                };
                return;
            }

            if (e.dataField === "UnitConversionID") {
                var rowDataForUnit = e.row && e.row.data ? e.row.data : null;
                var selectedItemIdForUnit = rowDataForUnit ? rowDataForUnit.ItemID : null;
                var optionsForUnit = rowDataForUnit && Array.isArray(rowDataForUnit.UnitOptions)
                    ? rowDataForUnit.UnitOptions
                    : [];

                e.editorName = "dxSelectBox";
                e.editorOptions.dataSource = optionsForUnit;
                e.editorOptions.displayExpr = "UnitName";
                e.editorOptions.valueExpr = "UnitConversionID";
                e.editorOptions.searchEnabled = true;
                e.editorOptions.showClearButton = true;

                if (selectedItemIdForUnit && optionsForUnit.length === 0) {
                    loadUnitOptionsForItem(selectedItemIdForUnit).then(function (options) {
                        if (rowDataForUnit) rowDataForUnit.UnitOptions = options;
                        e.component.repaintRows([e.row.rowIndex]);
                    });
                }
                return;
            }

            if (e.dataField === "Quantity") {
                e.editorName = "dxNumberBox";
                e.editorOptions.showSpinButtons = true;
                e.editorOptions.min = 0;
                e.editorOptions.step = 0.01;
                e.editorOptions.format = "#,##0.###";
            }
        }

        function getOrderGridRows() {
            var grid = $("#poDetailsGrid").dxDataGrid("instance");
            if (!grid) return [];
            var dataSource = grid.getDataSource();
            var rows = dataSource && dataSource.items ? dataSource.items() : [];
            return Array.isArray(rows) ? rows : [];
        }

        function buildPayload() {
            var accountId = $("#poAccountSelect").dxSelectBox("instance").option("value");
            var dueDate = $("#poDate").dxDateBox("instance").option("value");
            var remarks = $("#remarks").dxTextArea("instance").option("value");
            var detailRows = getOrderGridRows();

            return {
                OrderID: currentPurchaseOrderId,
                AccountID: accountId || null,
                DueDate: dueDate,
                Remarks: remarks,
                Details: detailRows.map(function (row) {
                    return {
                        ItemID: row.ItemID || null,
                        UnitConversionID: row.UnitConversionID || null,
                        Quantity: row.Quantity || null,
                        Remarks: row.Remarks || ""
                    };
                })
            };
        }

        function validatePayload(payload) {
            if (!payload.Details || payload.Details.length === 0) return "لږ تر لږه یو قطار اضافه کړئ.";

            for (var i = 0; i < payload.Details.length; i++) {
                var row = payload.Details[i];
                if (!row.ItemID) return "په ټولو قطارونو کې جنس ضروری دی.";
                if (row.UnitConversionID === null || row.UnitConversionID === undefined) return "په ټولو قطارونو کې واحد ضروری دی.";
                if (!row.Quantity || row.Quantity <= 0) return "په ټولو قطارونو کې مقدار باید له صفر څخه زیات وي.";
            }

            return "";
        }

        function validateTopControls() {
            var accountValidator = $("#poAccountSelect").dxValidator("instance");
            var dueDateValidator = $("#poDate").dxValidator("instance");

            var accountResult = accountValidator ? accountValidator.validate() : { isValid: true };
            var dueDateResult = dueDateValidator ? dueDateValidator.validate() : { isValid: true };

            return accountResult.isValid && dueDateResult.isValid;
        }

        function extractServerError(xhr) {
            if (xhr && xhr.responseJSON && xhr.responseJSON.Message) return xhr.responseJSON.Message;
            if (xhr && xhr.responseText) return xhr.responseText;
            return "د ثبت پر مهال ستونزه رامنځته شوه.";
        }

        function applyLoadedOrder(data) {
            if (!data) return;

            currentPurchaseOrderId = data.ID || null;

            var accountEditor = $("#poAccountSelect").dxSelectBox("instance");
            var dateEditor = $("#poDate").dxDateBox("instance");

            if (accountEditor) accountEditor.option("value", data.AccountID || null);
            if (dateEditor && data.DueDate) dateEditor.option("value", new Date(data.DueDate));

            orderRows.length = 0;
            rowCounter = 1;

            var detailRows = Array.isArray(data.Details) ? data.Details : [];
            for (var i = 0; i < detailRows.length; i++) {
                var row = detailRows[i];
                orderRows.push({
                    RowID: rowCounter++,
                    ItemID: row.ItemID || null,
                    UnitConversionID: row.UnitConversionID || null,
                    Quantity: row.Quantity || null,
                    Remarks: row.Remarks || "",
                    UnitOptions: []
                });
            }

            var grid = $("#poDetailsGrid").dxDataGrid("instance");
            if (grid) {
                grid.cancelEditData();
                grid.refresh();
            }

            var unitLoaders = [];
            for (var j = 0; j < orderRows.length; j++) {
                (function (targetRow) {
                    if (!targetRow.ItemID) return;
                    var loader = loadUnitOptionsForItem(targetRow.ItemID).then(function (options) {
                        targetRow.UnitOptions = options;
                    });
                    unitLoaders.push(loader);
                })(orderRows[j]);
            }

            if (unitLoaders.length > 0) {
                $.when.apply($, unitLoaders).always(function () {
                    var orderGrid = $("#poDetailsGrid").dxDataGrid("instance");
                    if (orderGrid) orderGrid.refresh();
                });
            }
        }

        function loadOrderForEdit(orderId) {
            if (!orderId || orderId <= 0) return;

            $.getJSON("/api/PurchaseOrders/" + orderId)
                .done(function (response) {
                    applyLoadedOrder(response);
                })
                .fail(function (xhr) {
                    DevExpress.ui.notify(extractServerError(xhr), "error", 3500);
                });
        }

        function onSaveClick() {
            if (!validateTopControls()) return;

            var grid = $("#poDetailsGrid").dxDataGrid("instance");
            var saveEditPromise = grid ? grid.saveEditData() : $.Deferred().resolve().promise();

            $.when(saveEditPromise).done(function () {
                var payload = buildPayload();
                var validationMessage = validatePayload(payload);

                if (validationMessage) {
                    DevExpress.ui.notify(validationMessage, "error", 2500);
                    return;
                }

                $.ajax({
                    url: '/api/PurchaseOrders',
                    method: "POST",
                    contentType: "application/json; charset=utf-8",
                    data: JSON.stringify(payload)
                }).done(function (response) {
                    if (response && response.OrderID) currentPurchaseOrderId = response.OrderID;

                    var successMessage = response && response.Message
                        ? response.Message
                        : "خرید آرډر په بریالیتوب ثبت شو.";

                    DevExpress.ui.notify(successMessage, "success", 2200);
                    onClearClick();
                }).fail(function (xhr) {
                    DevExpress.ui.notify(extractServerError(xhr), "error", 3500);
                });
            });
        }

        function onClearClick() {
            var accountEditor = $("#poAccountSelect").dxSelectBox("instance");
            var dateEditor = $("#poDate").dxDateBox("instance");
            var grid = $("#poDetailsGrid").dxDataGrid("instance");

            if (accountEditor) accountEditor.option("value", null);
            if (dateEditor) dateEditor.option("value", new Date());

            setContactFields(null);
            orderRows.length = 0;
            currentPurchaseOrderId = null;

            if (grid) {
                grid.cancelEditData();
                grid.refresh();
            }

            DevExpress.ui.notify("فورم پاک شو.", "info", 1500);
        }

        $(function () {
            setContactFields(null);
            refreshActiveItemsCache().always(function () {
                loadOrderForEdit(initialOrderId);
            });

            $("#poAccountSelect").dxValidator({
                validationRules: [
                    { type: "required", message: "حساب انتخاب کړئ." }
                ]
            });

            $("#poDate").dxValidator({
                validationRules: [
                    { type: "required", message: "د تادیې نېټه انتخاب کړئ." }
                ]
            });
        });

        return {
            accountDataSource: accountDataSource,
            orderRows: orderRows,
            accountDisplayExpr: accountDisplayExpr,
            onAccountChanged: onAccountChanged,
            getItemDisplayText: getItemDisplayText,
            getUnitDisplayText: getUnitDisplayText,
            onOrderGridInitNewRow: onOrderGridInitNewRow,
            onOrderGridEditorPreparing: onOrderGridEditorPreparing,
            onSaveClick: onSaveClick,
            onClearClick: onClearClick
        };
    })();
</script>
