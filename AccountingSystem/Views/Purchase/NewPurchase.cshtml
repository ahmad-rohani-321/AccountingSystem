<div id="pending-po-popup"></div>

<script>
    var purchasePage = (function () {
        var strictFullPaymentAccountTypeId = 10;

        var selectedPurchaseOrderId = null;
        var purchaseDetailsData = [];
        var purchaseRowCounter = 1;
        var unitOptionsByItemId = {};
        var activeItemsCache = [];
        var activeItemNameById = {};
        var activeWarehousesCache = [];
        var activeWarehouseNameById = {};
        var pendingOrdersPopup = null;

        var accountDataSource = new DevExpress.data.DataSource({
            store: DevExpress.data.AspNet.createStore({
                key: "AccountID",
                loadUrl: '@Url.Content("~/api/Accounts")',
                loadParams: { types: "4,5, 10" }
            }),
            paginate: true,
            pageSize: 200
        });

        var activeItemsDataSource = new DevExpress.data.DataSource({
            store: DevExpress.data.AspNet.createStore({
                key: "ID",
                loadUrl: '@Url.Content("~/api/Items")'
            }),
            paginate: true,
            pageSize: 200
        });

        var itemLookupDataSource = new DevExpress.data.DataSource({
            store: DevExpress.data.AspNet.createStore({
                key: "ID",
                loadUrl: '@Url.Content("~/api/Items")'
            }),
            filter: ["IsActive", "=", true],
            paginate: true,
            pageSize: 200
        });

        var activeWarehousesDataSource = new DevExpress.data.DataSource({
            store: DevExpress.data.AspNet.createStore({
                key: "ID",
                loadUrl: '@Url.Content("~/api/Warehouses/Active")'
            }),
            paginate: true,
            pageSize: 200
        });

        var warehouseLookupDataSource = new DevExpress.data.DataSource({
            store: DevExpress.data.AspNet.createStore({
                key: "ID",
                loadUrl: '@Url.Content("~/api/Warehouses/Active")'
            }),
            paginate: true,
            pageSize: 200
        });

        function unitLookupDataSource(options) {
            if (!options || !options.data) return [];
            var rowData = options.data;
            return Array.isArray(rowData.UnitOptions) ? rowData.UnitOptions : [];
        }

        function normalizeDxLoadResult(result) {
            if (Array.isArray(result)) return result;
            if (result && Array.isArray(result.data)) return result.data;
            return [];
        }

        function refreshActiveItemsCache() {
            return activeItemsDataSource.load().then(function (result) {
                var allRows = normalizeDxLoadResult(result);
                activeItemsCache = allRows.filter(function (row) { return row && row.IsActive; });
                activeItemNameById = {};

                for (var i = 0; i < activeItemsCache.length; i++) {
                    var item = activeItemsCache[i];
                    if (item && item.ID) activeItemNameById[item.ID] = item.NativeName || "";
                }

                return activeItemsCache;
            });
        }

        function refreshActiveWarehousesCache() {
            return activeWarehousesDataSource.load().then(function (result) {
                var allRows = normalizeDxLoadResult(result);
                activeWarehousesCache = allRows.filter(function (row) { return row && row.IsActive; });
                activeWarehouseNameById = {};

                for (var i = 0; i < activeWarehousesCache.length; i++) {
                    var warehouse = activeWarehousesCache[i];
                    if (warehouse && warehouse.ID) activeWarehouseNameById[warehouse.ID] = warehouse.Name || "";
                }

                return activeWarehousesCache;
            });
        }

        function loadUnitOptionsForItem(itemId) {
            if (!itemId) return $.Deferred().resolve([]).promise();
            if (unitOptionsByItemId[itemId]) return $.Deferred().resolve(unitOptionsByItemId[itemId]).promise();

            return $.getJSON("/api/Items/" + itemId + "/InitialStock/UnitOptions")
                .then(function (options) {
                    var rows = Array.isArray(options) ? options : [];
                    unitOptionsByItemId[itemId] = rows;
                    return rows;
                }, function () {
                    return [];
                });
        }

        function getItemDisplayText(rowData) {
            if (!rowData || !rowData.ItemID) return "";
            return activeItemNameById[rowData.ItemID] || rowData.ItemID;
        }

        function getUnitDisplayText(rowData) {
            if (!rowData || rowData.UnitConversionID === null || rowData.UnitConversionID === undefined) return "";

            var options = Array.isArray(rowData.UnitOptions) ? rowData.UnitOptions : [];
            for (var i = 0; i < options.length; i++) {
                var unit = options[i];
                if (unit && unit.UnitConversionID === rowData.UnitConversionID) {
                    return unit.UnitName || "";
                }
            }

            return rowData.UnitConversionID;
        }

        function getWarehouseDisplayText(rowData) {
            if (!rowData || !rowData.WarehouseID) return "";
            return activeWarehouseNameById[rowData.WarehouseID] || rowData.WarehouseID;
        }

        function updatePurchaseTotal() {
            var totalInstance = $("#purchase-total").dxNumberBox("instance");
            if (!totalInstance) return;

            var total = 0;
            var purchaseGrid = getPurchaseGrid();
            var rows = purchaseGrid ? purchaseGrid.getVisibleRows() : [];

            if (rows && rows.length) {
                for (var i = 0; i < rows.length; i++) {
                    var rowData = rows[i] && rows[i].data ? rows[i].data : null;
                    total += Number(rowData && rowData.TotalPrice ? rowData.TotalPrice : 0);
                }
            } else {
                for (var j = 0; j < purchaseDetailsData.length; j++) {
                    total += Number(purchaseDetailsData[j].TotalPrice || 0);
                }
            }

            totalInstance.option("value", total);
            syncSpecialAccountPaymentRule();
            updateRemainingAmount();
        }

        function updateRemainingAmount() {
            var totalInstance = $("#purchase-total").dxNumberBox("instance");
            var receivedInstance = $("#purchase-received").dxNumberBox("instance");
            var remainingInstance = $("#purchase-remaining").dxNumberBox("instance");
            if (!remainingInstance) return;

            var total = totalInstance ? Number(totalInstance.option("value") || 0) : 0;
            var received = receivedInstance ? Number(receivedInstance.option("value") || 0) : 0;
            remainingInstance.option("value", total - received);
        }

        function onReceivedAmountChanged() {
            updateRemainingAmount();
            refreshPaymentValidators();
        }

        function getAccountSelectorInstance() {
            return $("#account-selector").dxSelectBox("instance");
        }

        function getSelectedAccountItem() {
            var accountInstance = getAccountSelectorInstance();
            return accountInstance ? accountInstance.option("selectedItem") : null;
        }

        function getSelectedAccountTypeId() {
            var selectedAccount = getSelectedAccountItem();
            return selectedAccount ? Number(selectedAccount.AccountTypeID || 0) : 0;
        }

        function isStrictFullPaymentAccountSelected() {
            return getSelectedAccountTypeId() === strictFullPaymentAccountTypeId;
        }

        function syncSpecialAccountPaymentRule() {
            var receivedInstance = $("#purchase-received").dxNumberBox("instance");
            if (!receivedInstance) return;

            var shouldForceFullPayment = isStrictFullPaymentAccountSelected();
            receivedInstance.option("readOnly", shouldForceFullPayment);

            if (shouldForceFullPayment) {
                receivedInstance.option("value", getNumberBoxValue("#purchase-total"));
            }
        }

        function onPurchaseGridInitNewRow(e) {
            e.data.RowID = purchaseRowCounter++;
            e.data.ItemID = null;
            e.data.UnitConversionID = null;
            e.data.Quantity = null;
            e.data.UnitPrice = null;
            e.data.TotalPrice = null;
            e.data.WarehouseID = null;
            e.data.Remarks = "";
            e.data.UnitOptions = [];
        }

        function onPurchaseGridEditorPreparing(e) {
            if (e.parentType !== "dataRow") return;

            if (e.dataField === "ItemID") {
                e.editorName = "dxSelectBox";
                e.editorOptions.dataSource = activeItemsCache;
                e.editorOptions.displayExpr = "NativeName";
                e.editorOptions.valueExpr = "ID";
                e.editorOptions.searchEnabled = true;
                e.editorOptions.showClearButton = true;

                var baseItemChanged = e.editorOptions.onValueChanged;
                e.editorOptions.onValueChanged = function (args) {
                    if (baseItemChanged) baseItemChanged(args);

                    var selectedItemId = args && args.value ? args.value : null;
                    var rowIndex = e.row.rowIndex;
                    var grid = e.component;
                    var rowData = e.row && e.row.data ? e.row.data : null;

                    grid.cellValue(rowIndex, "ItemID", selectedItemId);
                    grid.cellValue(rowIndex, "UnitConversionID", null);
                    if (rowData) rowData.UnitOptions = [];

                    if (!selectedItemId) {
                        grid.repaintRows([rowIndex]);
                        return;
                    }

                    loadUnitOptionsForItem(selectedItemId).then(function (options) {
                        if (rowData) rowData.UnitOptions = options;
                        if (options.length === 1) {
                            grid.cellValue(rowIndex, "UnitConversionID", options[0].UnitConversionID);
                        }
                        grid.repaintRows([rowIndex]);
                    });
                };
                return;
            }

            if (e.dataField === "UnitConversionID") {
                var rowDataForUnit = e.row && e.row.data ? e.row.data : null;
                var selectedItemIdForUnit = rowDataForUnit ? rowDataForUnit.ItemID : null;
                var optionsForUnit = rowDataForUnit && Array.isArray(rowDataForUnit.UnitOptions)
                    ? rowDataForUnit.UnitOptions
                    : [];

                e.editorName = "dxSelectBox";
                e.editorOptions.dataSource = optionsForUnit;
                e.editorOptions.displayExpr = "UnitName";
                e.editorOptions.valueExpr = "UnitConversionID";
                e.editorOptions.searchEnabled = true;
                e.editorOptions.showClearButton = true;

                if (selectedItemIdForUnit && optionsForUnit.length === 0) {
                    loadUnitOptionsForItem(selectedItemIdForUnit).then(function (options) {
                        if (rowDataForUnit) rowDataForUnit.UnitOptions = options;
                        e.component.repaintRows([e.row.rowIndex]);
                    });
                }
                return;
            }

            if (e.dataField === "WarehouseID") {
                e.editorName = "dxSelectBox";
                e.editorOptions.dataSource = activeWarehousesCache;
                e.editorOptions.displayExpr = "Name";
                e.editorOptions.valueExpr = "ID";
                e.editorOptions.searchEnabled = true;
                e.editorOptions.showClearButton = true;
                return;
            }

            if (e.dataField === "Quantity" || e.dataField === "UnitPrice") {
                e.editorName = "dxNumberBox";
                e.editorOptions.showSpinButtons = true;
                e.editorOptions.min = 0;
                e.editorOptions.step = 0.01;
                e.editorOptions.format = "#,##0.###";

                var baseValueChanged = e.editorOptions.onValueChanged;
                e.editorOptions.onValueChanged = function (args) {
                    if (baseValueChanged) baseValueChanged(args);

                    var grid = e.component;
                    var rowIndex = e.row.rowIndex;

                    var quantity = Number(grid.cellValue(rowIndex, "Quantity") || 0);
                    var unitPrice = Number(grid.cellValue(rowIndex, "UnitPrice") || 0);
                    var total = quantity * unitPrice;

                    grid.cellValue(rowIndex, "TotalPrice", total);
                    if (e.row && e.row.data) {
                        e.row.data.TotalPrice = total;
                    }
                    updatePurchaseTotal();
                };
            }
        }

        function onPurchaseGridRowRemoved() {
            updatePurchaseTotal();
        }

        var treasureDataSource = new DevExpress.data.DataSource({
            store: DevExpress.data.AspNet.createStore({
                key: "AccountID",
                loadUrl: '@Url.Content("~/api/Accounts")',
                loadParams: { types: "1,2" }
            }),
            paginate: true,
            pageSize: 200
        });

        var currencyDataSource = new DevExpress.data.DataSource({
            store: DevExpress.data.AspNet.createStore({
                key: "ID",
                loadUrl: '@Url.Content("~/api/Currencies")'
            }),
            filter: ["IsActive", "=", true],
            paginate: true,
            pageSize: 200
        });

        var pendingPurchaseOrdersDataSource = DevExpress.data.AspNet.createStore({
            key: "ID",
            loadUrl: '@Url.Content("~/api/PurchaseOrders/GetPending")'
        });

        function accountDisplayExpr(item) {
            if (!item) return "";
            var accountName = item.Name || "";
            var accountCode = item.Code || "";
            return accountName + " - " + accountCode;
        }

        function formatNumeric(value) {
            if (value === null || value === undefined || Number.isNaN(Number(value))) return "0";
            return Number(value).toLocaleString("en-US", { minimumFractionDigits: 0, maximumFractionDigits: 2 });
        }

        function numberToWords(number) {
            var numericValue = Number(number);
            if (!Number.isFinite(numericValue)) return "";

            number = Math.trunc(numericValue);
            if (number === 0) return "ØµÙØ±";
            if (number < 0) return "Ù…Ù†ÙÛŒ " + numberToWords(Math.abs(number));

            var words = "";

            if (Math.floor(number / 1000000000) > 0) {
                if (Math.floor(number / 1000000000) >= 2) {
                    words += numberToWords(Math.floor(number / 1000000000)) + " Ù…ÛŒÙ„ÛŒØ§Ø±Ø¯Ù‡ ";
                } else {
                    words += " ÛŒÙˆ Ù…ÛŒÙ„ÛŒØ§Ø±Ø¯ ";
                }
                number %= 1000000000;
            }

            if (Math.floor(number / 1000000) > 0) {
                if (Math.floor(number / 1000000) >= 2) {
                    words += numberToWords(Math.floor(number / 1000000)) + " Ù…Ù„ÛŒÙˆÙ†Ù‡ ";
                } else {
                    words += " ÛŒÙˆ Ù…Ù„ÛŒÙˆÙ† ";
                }
                number %= 1000000;
            }

            if (Math.floor(number / 1000) > 0) {
                if (Math.floor(number / 1000) >= 2) {
                    words += numberToWords(Math.floor(number / 1000)) + " Ø²Ø±Ù‡ ";
                    number %= 1000;
                } else {
                    number %= 1000;
                    words += number > 0 ? " ÛŒÙˆ Ø²Ø± " : " Ø²Ø± ";
